# App
NEXT_PUBLIC_APP_NAME="Islah Web Service"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# AI / Groq
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"

# Admin auth (required — no default is provided)
# Password used to sign in at /admin/login
ADMIN_PASSWORD="change-me-to-a-strong-password"
# Secret (>= 16 chars) used to sign the admin session cookie.
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET="change-me-to-a-long-random-secret"

# Database
DATABASE_URL="postgres://user:password@host:5432/dbname"

# Email (Resend)
RESEND_API_KEY="re_..."
FROM_EMAIL="Islah Web Service <noreply@islahwebservice.com>"
TO_EMAIL="admin@islahwebservice.com"

# Images (Cloudinary)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
